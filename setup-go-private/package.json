{
  "name": "setup-go-private",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:setup && npm run build:teardown",
    "build:setup": "esbuild src/setup.ts --bundle --platform=node --target=node24 --outfile=dist/setup/index.js",
    "build:teardown": "esbuild src/teardown.ts --bundle --platform=node --target=node24 --outfile=dist/teardown/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
